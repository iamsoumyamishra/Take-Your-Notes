generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id       String    @id @default(cuid())
  title    String
  content  String?   @default("")
  date     DateTime? @default(now())
  url      String?   @default("")
  imageUrl String?   @default("")
  type     String[]  @default(["text"])
  tags     String[]  @default([])
}

